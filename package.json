{
  "name": "gpt-chat-bot",
  "version": "1.0.0",
  "description": "A Telegram bot using GPT for chatting.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "cross-env NODE_ENV=development nodemon --watch 'src/**/*' --exec 'ts-node' src/index.ts",
    "start": "cross-env NODE_ENV=production node ./dist/index.js",
    "test": "jest",
    "lint": "eslint . --ext .ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PanDmitriy/gpt-chat-tg-bot.git"
  },
  "keywords": [
    "telegram",
    "bot",
    "gpt",
    "typescript"
  ],
  "author": "Dmitry Panzhinsky",
  "license": "ISC",
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@types/node": "^22.8.1",
    "axios": "^1.4.0",
    "config": "^3.3.9",
    "fluent-ffmpeg": "^2.1.2",
    "openai": "^3.2.1",
    "telegraf": "^4.12.2",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@telegraf/types": "^7.1.0",
    "@types/jest": "^29.5.14",
    "cross-env": "^7.0.3",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  }
}
